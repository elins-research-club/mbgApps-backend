generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model Bahan {
  id                Int      @id @default(autoincrement())
  nama              String   @unique
  energi_kkal       Float?   @default(0)
  protein_g         Float?   @default(0)
  lemak_g           Float?   @default(0)
  karbohidrat_g     Float?   @default(0)
  serat_g           Float?   @default(0)
  abu_g             Float?   @default(0)
  kalsium_mg        Float?   @default(0)
  fosfor_mg         Float?   @default(0)
  besi_mg           Float?   @default(0)
  natrium_mg        Float?   @default(0)
  kalium_mg         Float?   @default(0)
  tembaga_mg        Float?   @default(0)
  seng_mg           Float?   @default(0)
  retinol_mcg       Float?   @default(0)
  b_kar_mcg         Float?   @default(0)
  karoten_total_mcg Float?   @default(0)
  thiamin_mg        Float?   @default(0)
  riboflavin_mg     Float?   @default(0)
  niasin_mg         Float?   @default(0)
  vitamin_c_mg      Float?   @default(0)
  kelompok_makanan  String?
  kategori_makanan  String?
  isValidated       Boolean? @default(false)
  validatedBy       String
  Resep             Resep[]

  @@schema("public")
}

model MealPlan {
  id             String   @id
  name           String
  targetClass    Float?   @default(0)
  recipes        String
  totalNutrition String
  org_id         String?  @db.Uuid
  created_by     String?  @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  Organizations  Organizations? @relation("OrganizationMealPlans", fields: [org_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mealplan_org_id_fkey")
  CreatedByUser  Userext?       @relation("UserCreatedMealPlans", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mealplan_created_by_fkey")

  @@schema("public")
}



model Membership {
  id            String        @id(map: "membership_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String        @db.Uuid
  user_id       String        @db.Uuid
  role_id       String?       @db.Uuid
  status        String        @default("pending")
  invited_by    String?       @db.Uuid
  invite_method String        @default("request")
  joined_at     DateTime?     @db.Timestamptz(6)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  Organizations Organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "membership_org_id_fkey")
  Roles         Roles?        @relation(fields: [role_id], references: [id], onUpdate: NoAction, map: "membership_role_id_fkey")
  Userext       Userext?      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "membership_user_id_fkey")

  @@unique([org_id, user_id], map: "membership_org_id_user_id_key")
  @@schema("public")
}

model Menu {
  id       Int     @id @default(autoincrement())
  nama     String  @unique
  kategori String
  org_id   String?  @db.Uuid
  created_by String? @db.Uuid
  Organizations Organizations? @relation("OrganizationMenus", fields: [org_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "menu_org_id_fkey")
  CreatedBy  Userext?       @relation("UserCreatedMenus", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "menu_created_by_fkey")
  Resep    Resep[]

  @@schema("public")
}


model Organizations {
  id          String       @id(map: "organizations_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  owner_id    String       @db.Uuid
  parent_id   String?      @db.Uuid
  depth       Int          @default(0)
  invite_code String       @unique(map: "organizations_invite_code_key") @default(dbgenerated("upper(\"substring\"(md5((gen_random_uuid())::text), 1, 8))"))
  status      String       @default("pending")
  approved_by String?      @db.Uuid
  approved_at DateTime?
  rejection_reason String?
  suspension_reason String?
  suspended_until DateTime?
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  updated_at  DateTime     @default(now()) @db.Timestamptz(6)
  Parent      Organizations?  @relation("OrganizationHierarchy", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "organizations_parent_id_fkey")
  Children    Organizations[] @relation("OrganizationHierarchy")
  Membership  Membership[]
  Roles       Roles[]
  Menus       Menu[]          @relation("OrganizationMenus")
  MealPlans   MealPlan[]      @relation("OrganizationMealPlans")

  @@index([parent_id], map: "organizations_parent_id_idx")
  @@schema("public")
}

model Resep {
  id       Int   @id @default(autoincrement())
  menu_id  Int
  bahan_id Int
  gramasi  Float
  Bahan    Bahan @relation(fields: [bahan_id], references: [id])
  Menu     Menu  @relation(fields: [menu_id], references: [id])

  @@schema("public")
}

model Roles {
  id            String        @id(map: "roles_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String        @db.Uuid
  name          String
  permissions   Json          @default("{}")
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  Membership    Membership[]
  Organizations Organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "roles_org_id_fkey")

  @@schema("public")
}


model Userext {
  id            String       @id(map: "userext_pkey") @db.Uuid
  full_name     String?
  phone         String?
  role          String?      @default("User")
  is_super_admin Boolean     @default(false)
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime     @default(now()) @db.Timestamptz(6)
  Membership    Membership[]
  CreatedMenus  Menu[]       @relation("UserCreatedMenus")
  CreatedMealPlans MealPlan[] @relation("UserCreatedMealPlans")

  @@schema("public")
}